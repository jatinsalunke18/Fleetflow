generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("Dispatcher") // Roles: Fleet Manager, Dispatcher, Safety Officer, Financial Analyst
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Vehicle {
  id           Int      @id @default(autoincrement())
  name         String
  licensePlate String   @unique
  maxCapacity  Int      // in kg
  odometer     Float    @default(0.0)
  status       String   @default("AVAILABLE") // AVAILABLE, ON_TRIP, IN_SHOP, RETIRED
  trips        Trip[]
  maintenance  MaintenanceLog[]
  fuelLogs     FuelLog[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Driver {
  id                 Int      @id @default(autoincrement())
  name               String
  licenseNumber      String   @unique
  licenseExpiry      DateTime
  safetyScore        Int      @default(100)
  tripCompletionRate Float    @default(100.0)
  status             String   @default("OFF_DUTY") // ON_DUTY, OFF_DUTY, SUSPENDED, ON_TRIP
  trips              Trip[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Trip {
  id           Int       @id @default(autoincrement())
  vehicleId    Int
  driverId     Int
  cargoWeight  Int       // in kg
  status       String    @default("DRAFT") // DRAFT, DISPATCHED, COMPLETED, CANCELLED
  startDate    DateTime  @default(now())
  endDate      DateTime?
  vehicle      Vehicle   @relation(fields: [vehicleId], references: [id])
  driver       Driver    @relation(fields: [driverId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model MaintenanceLog {
  id          Int      @id @default(autoincrement())
  vehicleId   Int
  description String
  cost        Float
  dateLogged  DateTime @default(now())
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])
}

model FuelLog {
  id          Int      @id @default(autoincrement())
  vehicleId   Int
  litersUsed  Float
  cost        Float
  dateLogged  DateTime @default(now())
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])
}
